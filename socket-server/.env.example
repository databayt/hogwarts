# Hogwarts realtime + WhatsApp stack — secrets for docker-compose.yml
#
# Copy to .env on the Oracle VM (cd /opt/hogwarts/socket-server) and fill in.
# Generate URL-safe values with:  openssl rand -hex 32
#
# CRITICAL: SOCKET_SECRET, EMIT_SECRET, EVOLUTION_API_KEY and
# WHATSAPP_WEBHOOK_SECRET must MATCH the values set on Vercel (Production).
# Use hex (not base64) — the webhook secret is read from a URL query string,
# where base64 '+' decodes to a space and breaks the constant-time compare.

# Socket.IO — JWT signing for the client handshake. Match Vercel SOCKET_SECRET.
SOCKET_SECRET=

# Socket.IO — guards POST /api/emit*. Match Vercel EMIT_SECRET.
EMIT_SECRET=

# Evolution API admin key (apikey header). Match Vercel EVOLUTION_API_KEY.
EVOLUTION_API_KEY=

# Postgres password for Evolution's metadata DB (VM-local only, not on Vercel).
DB_PASSWORD=

# NOTE: WHATSAPP_WEBHOOK_SECRET is NOT consumed by this stack — the app appends
# it to each instance's webhook URL (?secret=) at QR-connect time. It only needs
# to be set on Vercel. Recorded here for the operator's reference:
# WHATSAPP_WEBHOOK_SECRET=
