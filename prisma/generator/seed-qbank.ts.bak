async function ensureQuestions(schoolId: string, questionBanks: any[]) {
  console.log("Seeding Questions...");

  const questionsBySubject = new Map();

  // Islamic Studies
  const islamicBank = questionBanks.find((b) => b.name.includes("Islamic Studies"));
  if (islamicBank) {
    questionsBySubject.set(islamicBank.id, ISLAMIC_STUDIES_QUESTIONS);
  }

  // Arabic
  const arabicBank = questionBanks.find((b) => b.name.includes("Arabic Language"));
  if (arabicBank) {
    questionsBySubject.set(arabicBank.id, ARABIC_QUESTIONS);
  }

  // Mathematics
  const mathBank = questionBanks.find((b) => b.name.includes("Mathematics"));
  if (mathBank) {
    questionsBySubject.set(mathBank.id, MATHEMATICS_QUESTIONS);
  }

  // English
  const englishBank = questionBanks.find((b) => b.name.includes("English Language"));
  if (englishBank) {
    questionsBySubject.set(englishBank.id, ENGLISH_QUESTIONS);
  }

  let totalQuestions = 0;

  // Create questions for each subject
  for (const [bankId, questions] of questionsBySubject) {
    for (const q of questions) {
      const existing = await prisma.question.findFirst({
        where: { schoolId, questionBankId: bankId, questionText: q.question },
      });

      if (!existing) {
        await prisma.question.create({
          data: {
            schoolId,
            questionBankId: bankId,
            questionText: q.question,
            questionType: q.type,
            difficulty: q.difficulty,
            points: q.points.toString(),
            correctAnswer: q.correctAnswer,
            options: q.options ? JSON.stringify(q.options) : null,
            isActive: true,
          },
        });
        totalQuestions++;
      }
    }

    // Generate additional generic questions to reach target count
    const currentCount = await prisma.question.count({ where: { questionBankId: bankId } });
    const targetCount = 50; // 50 questions per subject

    if (currentCount < targetCount) {
      const additionalQuestions: any[] = [];
      for (let i = currentCount; i < targetCount; i++) {
        const types = [QuestionType.MULTIPLE_CHOICE, QuestionType.SHORT_ANSWER, QuestionType.ESSAY];
        const difficulties = [QuestionDifficulty.EASY, QuestionDifficulty.MEDIUM, QuestionDifficulty.HARD];
        const type = faker.helpers.arrayElement(types);
        const difficulty = faker.helpers.arrayElement(difficulties);

        additionalQuestions.push({
          schoolId,
          questionBankId: bankId,
          questionText: `Sample Question ${i + 1} (${type})`,
          questionType: type,
          difficulty,
          points: (difficulty === QuestionDifficulty.EASY ? 2 : difficulty === QuestionDifficulty.MEDIUM ? 5 : 10).toString(),
          correctAnswer: type === QuestionType.MULTIPLE_CHOICE ? "A" : "Sample answer",
          options: type === QuestionType.MULTIPLE_CHOICE ? JSON.stringify(["A", "B", "C", "D"]) : null,
          isActive: true,
        });
      }

      await prisma.question.createMany({ data: additionalQuestions, skipDuplicates: true });
      totalQuestions += additionalQuestions.length;
    }
  }

  console.log(`✅ Seeded ${totalQuestions} Questions`);
}

async function ensureExamTemplates(schoolId: string, questionBanks: any[]) {
  console.log("Seeding Exam Templates...");

  const templates: any[] = [];

  for (const bank of questionBanks) {
    const subject = await prisma.subject.findUnique({ where: { id: bank.subjectId } });
    if (!subject) continue;

    // Midterm template
    const midtermName = `${subject.subjectName} - Midterm Template`;
    const existingMidterm = await prisma.examTemplate.findFirst({
      where: { schoolId, name: midtermName },
    });

    if (!existingMidterm) {
      const midterm = await prisma.examTemplate.create({
        data: {
          schoolId,
          questionBankId: bank.id,
          name: midtermName,
          description: `Standard midterm examination template for ${subject.subjectName}`,
          duration: 120, // 2 hours
          totalMarks: 100,
          passingMarks: 50,
          instructions: "Answer all questions. Show your work for calculations. Write clearly and legibly.",
          questionSelection: JSON.stringify({
            easy: 10,
            medium: 5,
            hard: 2,
          }),
          isActive: true,
        },
      });
      templates.push(midterm);
    }

    // Final exam template
    const finalName = `${subject.subjectName} - Final Exam Template`;
    const existingFinal = await prisma.examTemplate.findFirst({
      where: { schoolId, name: finalName },
    });

    if (!existingFinal) {
      const final = await prisma.examTemplate.create({
        data: {
          schoolId,
          questionBankId: bank.id,
          name: finalName,
          description: `Comprehensive final examination template for ${subject.subjectName}`,
          duration: 180, // 3 hours
          totalMarks: 100,
          passingMarks: 50,
          instructions: "Answer all questions. Time management is important. Read instructions carefully for each section.",
          questionSelection: JSON.stringify({
            easy: 15,
            medium: 10,
            hard: 5,
          }),
          isActive: true,
        },
      });
      templates.push(final);
    }
  }

  console.log(`✅ Seeded ${templates.length} Exam Templates`);
}

async function ensureRubrics(schoolId: string) {
  console.log("Seeding Rubrics for Essay Grading...");

  const rubrics = [
    {
      name: "Essay Writing Rubric - General",
      description: "Standard rubric for evaluating essay responses",
      maxScore: 20,
      criteria: [
        { name: "Content & Ideas", description: "Quality and relevance of ideas presented", weight: 40, maxPoints: 8 },
        { name: "Organization & Structure", description: "Logical flow and paragraph structure", weight: 20, maxPoints: 4 },
        { name: "Language & Grammar", description: "Proper use of language, grammar, and spelling", weight: 25, maxPoints: 5 },
        { name: "Creativity & Insight", description: "Original thinking and depth of analysis", weight: 15, maxPoints: 3 },
      ],
    },
    {
      name: "Arabic Composition Rubric",
      description: "تقييم الإنشاء العربي (Arabic essay evaluation rubric)",
      maxScore: 20,
      criteria: [
        { name: "المحتوى والأفكار (Content)", description: "جودة الأفكار وارتباطها بالموضوع", weight: 40, maxPoints: 8 },
        { name: "النحو والإعراب (Grammar)", description: "الصحة النحوية والإعرابية", weight: 30, maxPoints: 6 },
        { name: "الأسلوب والبلاغة (Style)", description: "جمال الأسلوب واستخدام البلاغة", weight: 20, maxPoints: 4 },
        { name: "الإملاء والترقيم (Spelling)", description: "صحة الإملاء واستخدام علامات الترقيم", weight: 10, maxPoints: 2 },
      ],
    },
    {
      name: "Islamic Studies Essay Rubric",
      description: "Rubric for evaluating Islamic Studies written responses",
      maxScore: 15,
      criteria: [
        { name: "Islamic Knowledge", description: "Accuracy of Islamic concepts and references", weight: 50, maxPoints: 7.5 },
        { name: "Quranic/Hadith Citations", description: "Proper use of Islamic sources", weight: 25, maxPoints: 3.75 },
        { name: "Clarity of Explanation", description: "Clear and understandable explanations", weight: 25, maxPoints: 3.75 },
      ],
    },
  ];

  const createdRubrics: any[] = [];

  for (const rubric of rubrics) {
    const { criteria, ...rubricData } = rubric;
    const existing = await prisma.rubric.findFirst({
      where: { schoolId, name: rubric.name },
    });

    if (!existing) {
      const created = await prisma.rubric.create({
        data: {
          schoolId,
          ...rubricData,
        },
      });

      // Create criteria
      for (const criterion of criteria) {
        await prisma.rubricCriterion.create({
          data: {
            schoolId,
            rubricId: created.id,
            ...criterion,
          },
        });
      }

      createdRubrics.push(created);
    }
  }

  console.log(`✅ Seeded ${createdRubrics.length} Rubrics with Criteria`);
}

async function main() {
  console.log("🌱 Starting Question Bank Module Seed...");

  const school = await getSchool();
  console.log(`✅ School found: ${school.name}`);

  const questionBanks = await ensureQuestionBanks(school.id);
  await ensureQuestions(school.id, questionBanks || []);
  await ensureExamTemplates(school.id, questionBanks || []);
  await ensureRubrics(school.id);

  console.log("✅✅✅ Question Bank Module Seed completed successfully!");
  console.log(`📊 Question Bank Summary:`);
  console.log(`   - Question Banks: ${questionBanks?.length || 0} (one per subject)`);
  console.log(`   - Questions: ~${(questionBanks?.length || 0) * 50} (50 per subject)`);
  console.log(`   - Exam Templates: ${(questionBanks?.length || 0) * 2} (2 per subject)`);
  console.log(`   - Rubrics: 3 (General, Arabic, Islamic Studies)`);
  console.log(`   - Question Types: MCQ, Short Answer, Essay`);
  console.log(`   - Difficulty Levels: Easy, Medium, Hard`);
  console.log(`   - Languages: English & Arabic (bilingual content)`);
}

main()
  .catch((e) => {
    console.error(e);
    process.exit(1);
  })
  .finally(async () => {
    await prisma.$disconnect();
  });
