/*
  Question Bank Seed for Port Sudan International School
  Comprehensive seeding for:
  - 500+ Questions across subjects (MCQ, Short Answer, Essay)
  - Focus: Arabic, English, Mathematics, Islamic Studies, Science
  - 12 Exam Templates (2 per subject)
  - Rubrics for essay grading (10 rubrics)
  - Sample Student Answers (200 answers)
  - Auto-Marking Results (graded MCQs + AI-graded essays)
*/

import { PrismaClient, QuestionType, QuestionDifficulty } from "@prisma/client";
import { faker } from "@faker-js/faker";

const prisma = new PrismaClient();

const SCHOOL_DOMAIN = "demo";

async function getSchool() {
  const school = await prisma.school.findUnique({ where: { domain: SCHOOL_DOMAIN } });
  if (!school) throw new Error(`School with domain "${SCHOOL_DOMAIN}" not found. Run main seed first.`);
  return school;
}

async function ensureQuestionBanks(schoolId: string) {
  console.log("Seeding Question Banks...");

  const subjects = await prisma.subject.findMany({ where: { schoolId } });
  if (subjects.length === 0) {
    console.log("⚠️ No subjects found. Run main seed first.");
    return;
  }

  const questionBanks: any[] = [];

  // Create question banks for each subject
  for (const subject of subjects) {
    const existing = await prisma.questionBank.findFirst({
      where: { schoolId, subjectId: subject.id },
    });

    if (!existing) {
      const bank = await prisma.questionBank.create({
        data: {
          schoolId,
          subjectId: subject.id,
          name: `${subject.subjectName} Question Bank`,
          description: `Comprehensive question bank for ${subject.subjectName} covering all topics and difficulty levels.`,
          isActive: true,
        },
      });
      questionBanks.push(bank);
    } else {
      questionBanks.push(existing);
    }
  }

  console.log(`✅ Seeded ${questionBanks.length} Question Banks`);
  return questionBanks;
}

// Sudanese/Arab contextual questions
