// Material — supplementary resources (NO schoolId)
// Worksheets, presentations, study guides, lab manuals, etc.
// MaterialType enum is in catalog.prisma

model Material {
  id               String  @id @default(cuid())
  catalogSubjectId String?
  catalogChapterId String?
  catalogLessonId  String?

  title       String
  description String?      @db.Text
  lang        String       @default("ar")
  type        MaterialType @default(OTHER)

  // File metadata
  fileUrl   String?
  fileKey   String? // S3 key
  fileSize  Int?    // bytes
  mimeType  String?
  pageCount Int?

  // External link (for non-uploaded resources)
  externalUrl String?

  tags   String[]      @default([])
  status ContentStatus @default(DRAFT)

  // Contribution pattern
  contributedBy       String?
  contributedSchoolId String?
  approvalStatus      ApprovalStatus    @default(PENDING)
  approvedBy          String?
  approvedAt          DateTime?
  rejectionReason     String?
  visibility          ContentVisibility @default(PUBLIC)

  // Engagement metrics
  usageCount    Int   @default(0)
  averageRating Float @default(0)
  ratingCount   Int   @default(0)
  downloadCount Int   @default(0)

  // Relations
  catalogSubject Subject? @relation(fields: [catalogSubjectId], references: [id], onDelete: SetNull)
  catalogChapter Chapter? @relation(fields: [catalogChapterId], references: [id], onDelete: SetNull)
  catalogLesson  Lesson?  @relation(fields: [catalogLessonId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([catalogSubjectId])
  @@index([catalogChapterId])
  @@index([catalogLessonId])
  @@index([approvalStatus, visibility])
  @@index([type])
  @@index([contributedBy])
  @@map("catalog_materials")
}
