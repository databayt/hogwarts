// Lesson — third level of the catalog hierarchy (Subject → Chapter → Lesson)

model Lesson {
  id              String        @id @default(cuid())
  chapterId       String
  name            String
  slug            String
  lang            String        @default("ar")
  description     String?       @db.Text
  sequenceOrder   Int
  concept         String? // inherits from chapter if null
  thumbnail       String?       @map("thumbnailKey") // S3 key prefix for thumbnail WebP variants
  color           String?
  durationMinutes Int?
  objectives      String?       @db.Text
  gradeRange      String?
  grades          Int[]         @default([])
  levels          SchoolLevel[]
  status          ContentStatus @default(PUBLISHED)

  // Source provenance (US inventory)
  clickviewCoverId String?
  videoCount       Int     @default(0)
  resourceCount    Int     @default(0)

  // Engagement metrics
  usageCount    Int   @default(0)
  averageRating Float @default(0)
  ratingCount   Int   @default(0)

  // Relations
  chapter     Chapter           @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  videos      Video[]
  attachments Attachment[]
  overrides   ContentOverride[] @relation("LessonOverrides")
  progress    LessonProgress[]
  exams       Exam[]            @relation("LessonExams")

  // Content relations
  questions   Question[]
  materials   Material[]
  assignments Assignment[]
  quizzes     Quiz[]
  documents   Document[]

  // School-scoped reverse relations (FK bridges)
  schoolQuestionBanks QuestionBank[]
  schoolExams         SchoolExam[]
  schoolAssignments   SchoolAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([chapterId, slug])
  @@index([chapterId, sequenceOrder])
  @@index([status])
  @@map("catalog_lessons")
}
