// Quiz — lightweight gamified practice (NO schoolId)
// Distinct from Exam (formal assessment)
// QuizQuestion — junction table linking Quiz ↔ Question

model Quiz {
  id        String  @id @default(cuid())
  subjectId String
  chapterId String?
  lessonId  String?

  title       String
  description String? @db.Text
  lang        String  @default("ar")
  quizType    String  // PRACTICE, TIMED, FLASHCARD, COMPETITIVE
  timeLimit   Int?    // seconds

  status ContentStatus @default(DRAFT)
  tags   String[]      @default([])

  // Contribution pattern
  contributedBy       String?
  contributedSchoolId String?
  approvalStatus      ApprovalStatus    @default(PENDING)
  visibility          ContentVisibility @default(PUBLIC)

  // Engagement metrics
  usageCount   Int   @default(0)
  averageScore Float @default(0)

  // Relations
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  chapter   Chapter? @relation(fields: [chapterId], references: [id], onDelete: SetNull)
  lesson    Lesson?  @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  questions QuizQuestion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([subjectId])
  @@index([chapterId])
  @@index([status])
  @@index([approvalStatus, visibility])
  @@map("catalog_quizzes")
}

model QuizQuestion {
  id         String @id @default(cuid())
  quizId     String
  questionId String

  order  Int
  points Decimal @db.Decimal(5, 2)

  quiz     Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([quizId, order])
  @@unique([quizId, questionId])
  @@map("catalog_quiz_questions")
}
