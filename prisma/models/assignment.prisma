// Assignment — catalog-level homework/project templates (NO schoolId)
// Schools adopt these via SchoolAssignment mirror

model Assignment {
  id               String  @id @default(cuid())
  catalogSubjectId String?
  catalogChapterId String?
  catalogLessonId  String?

  title        String
  description  String?  @db.Text
  lang         String   @default("ar")
  instructions String?  @db.Text
  rubric       String?  @db.Text // Grading rubric

  // Assignment metadata
  totalPoints     Decimal? @db.Decimal(5, 2)
  estimatedTime   Int?     // minutes
  assignmentType  String?  // homework, project, lab, essay, presentation

  tags   String[]      @default([])
  status ContentStatus @default(DRAFT)

  // Contribution pattern
  contributedBy       String?
  contributedSchoolId String?
  approvalStatus      ApprovalStatus    @default(PENDING)
  approvedBy          String?
  approvedAt          DateTime?
  rejectionReason     String?
  visibility          ContentVisibility @default(PUBLIC)

  // Engagement metrics
  usageCount    Int   @default(0)
  averageRating Float @default(0)
  ratingCount   Int   @default(0)

  // Relations
  catalogSubject Subject? @relation(fields: [catalogSubjectId], references: [id], onDelete: SetNull)
  catalogChapter Chapter? @relation(fields: [catalogChapterId], references: [id], onDelete: SetNull)
  catalogLesson  Lesson?  @relation(fields: [catalogLessonId], references: [id], onDelete: SetNull)

  // School mirrors (adopted by schools)
  schoolAssignments SchoolAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([catalogSubjectId])
  @@index([catalogChapterId])
  @@index([catalogLessonId])
  @@index([approvalStatus, visibility])
  @@index([contributedBy])
  @@map("catalog_assignments")
}
