// Exam — formal assessment templates (NO schoolId)
// ExamTemplate — reusable exam blueprints with distribution rules
// ExamBlueprint — subject-category defaults (STEM_MATH, etc.)
// PaperTemplate — print layout configuration

model Exam {
  id          String  @id @default(cuid())
  subjectId   String
  chapterId   String?
  lessonId    String?
  title       String
  description String? @db.Text
  lang        String  @default("ar")

  examType        String // midterm, final, chapter_test, practice
  durationMinutes Int?
  totalMarks      Int?
  passingMarks    Int?
  questions       Json? // Legacy: use ExamQuestion junction instead
  totalQuestions  Int?
  distribution    Json? // e.g. {"MULTIPLE_CHOICE": {"EASY": 5}}
  bloomDistribution Json? // e.g. {"REMEMBER": 4, "UNDERSTAND": 3}

  gradeRange String?
  levels     SchoolLevel[]
  status     ContentStatus @default(DRAFT)
  tags       String[]      @default([])

  // Contribution pattern
  contributedBy       String?
  contributedSchoolId String?
  approvalStatus      ApprovalStatus    @default(PENDING)
  approvedBy          String?
  approvedAt          DateTime?
  rejectionReason     String?
  visibility          ContentVisibility @default(PUBLIC)

  // Engagement metrics
  usageCount   Int   @default(0)
  averageScore Float @default(0)
  qualityScore Float @default(0)
  ratingCount  Int   @default(0)

  // Pricing for PAID visibility
  price    Decimal? @db.Decimal(8, 2)
  currency String?  @default("USD")

  // Variant support (self-referencing)
  variantOf    String?
  variantLabel String?

  // Relations
  subject Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  chapter Chapter? @relation(fields: [chapterId], references: [id], onDelete: SetNull)
  lesson  Lesson?  @relation("LessonExams", fields: [lessonId], references: [id], onDelete: SetNull)

  // Variant relations
  parentExam Exam?  @relation("ExamVariants", fields: [variantOf], references: [id], onDelete: SetNull)
  variants   Exam[] @relation("ExamVariants")

  // Junction table for questions
  examQuestions ExamQuestion[]

  // School mirrors (adopted by schools)
  schoolExams SchoolExam[] @relation("CatalogExamMirror")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([subjectId])
  @@index([chapterId])
  @@index([lessonId])
  @@index([status])
  @@index([approvalStatus, visibility])
  @@index([contributedBy])
  @@index([contributedSchoolId])
  @@index([variantOf])
  @@map("catalog_exams")
}

// Reusable exam blueprints with distribution/Bloom rules
model ExamTemplate {
  id               String  @id @default(cuid())
  catalogSubjectId String
  name             String
  description      String? @db.Text
  lang             String  @default("ar")

  examType    String // midterm, final, chapter_test, quiz, practice, diagnostic
  duration    Int // Minutes
  totalMarks  Decimal @db.Decimal(6, 2)

  distribution      Json // {"MULTIPLE_CHOICE": {"EASY": 5, "MEDIUM": 3}}
  bloomDistribution Json?

  gradeRange String?
  levels     SchoolLevel[]

  // Contribution pattern
  contributedBy       String?
  contributedSchoolId String?
  approvalStatus      ApprovalStatus    @default(PENDING)
  approvedBy          String?
  approvedAt          DateTime?
  rejectionReason     String?
  visibility          ContentVisibility @default(PUBLIC)

  usageCount Int @default(0)
  status ContentStatus @default(PUBLISHED)
  tags   String[]      @default([])

  // Relations
  catalogSubject Subject @relation(fields: [catalogSubjectId], references: [id], onDelete: Cascade)

  // School mirrors (adopted templates)
  schoolMirrors SchoolExamTemplate[] @relation("CatalogExamTemplateMirror")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([catalogSubjectId])
  @@index([examType])
  @@index([status])
  @@index([approvalStatus, visibility])
  @@index([contributedBy])
  @@index([contributedSchoolId])
  @@map("catalog_exam_templates")
}

// Subject-category blueprints (STEM_MATH, LANGUAGE_ARTS, etc.)
model ExamBlueprint {
  id       String @id @default(cuid())
  category String @unique
  name     String
  description String? @db.Text

  questionTypeWeights Json
  bloomWeights        Json
  difficultyCurves    Json
  examTypeConfigs     Json
  questionTemplates   Json?
  mcqOptionGenerators Json?
  classificationRules Json?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@map("catalog_exam_blueprints")
}

// Exam paper layout configuration (NO schoolId)
model PaperTemplate {
  id   String @id @default(cuid())
  name String
  lang String @default("ar")

  template        String @default("CLASSIC")
  layout          String @default("SINGLE_COLUMN")
  answerSheetType String @default("SEPARATE")

  showSchoolLogo     Boolean @default(true)
  showExamTitle      Boolean @default(true)
  showInstructions   Boolean @default(true)
  customInstructions String? @db.Text
  showStudentInfo    Boolean @default(true)

  showQuestionNumbers   Boolean @default(true)
  showPointsPerQuestion Boolean @default(true)
  showQuestionType      Boolean @default(false)
  shuffleQuestions      Boolean @default(false)
  shuffleOptions        Boolean @default(false)

  answerLinesShort Int @default(3)
  answerLinesEssay Int @default(12)

  showPageNumbers Boolean @default(true)
  showTotalPages  Boolean @default(true)
  customFooter    String?
  pageSize        String  @default("A4")
  orientation     String  @default("portrait")

  blockConfig Json?

  // Contribution pattern
  contributedBy       String?
  contributedSchoolId String?
  approvalStatus      ApprovalStatus    @default(PENDING)
  approvedBy          String?
  approvedAt          DateTime?
  rejectionReason     String?
  visibility          ContentVisibility @default(PUBLIC)

  usageCount Int @default(0)
  status ContentStatus @default(PUBLISHED)
  tags   String[]      @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([approvalStatus, visibility])
  @@index([template])
  @@map("catalog_paper_templates")
}
