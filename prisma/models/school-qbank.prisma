// ============================================================================
// SCHOOL QUESTION BANK SYSTEM (has schoolId)
// ============================================================================
// Renamed: ExamTemplate → SchoolExamTemplate (avoids conflict with catalog ExamTemplate)
// Enums moved to catalog.prisma: QuestionType, DifficultyLevel, BloomLevel, QuestionSource
// Remaining enums stay here: SourceType, ProcessingStatus, JobStatus, ReviewStatus
// Catalog references updated: CatalogSubject→Subject, CatalogChapter→Chapter,
//   CatalogLesson→Lesson, CatalogQuestion→Question, CatalogExamTemplate→ExamTemplate
// ============================================================================

// ========== SCHOOL-SPECIFIC ENUMS ==========

enum SourceType {
  PDF_TEXTBOOK
  PDF_STUDY_GUIDE
  WEB_ARTICLE
  VIDEO_TRANSCRIPT
  CURRICULUM_DOCUMENT
  CLINICAL_GUIDELINE
  RESEARCH_PAPER
  LECTURE_NOTES
  PAST_PAPER
}

enum ProcessingStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  ARCHIVED
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
  PAUSED
}

enum ReviewStatus {
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
  NEEDS_REVISION
}

// ========== CORE QUESTION BANK ==========

model QuestionBank {
  id           String          @id @default(cuid())
  schoolId     String
  subjectId    String
  questionText String          @db.Text
  questionType QuestionType
  difficulty   DifficultyLevel
  bloomLevel   BloomLevel
  points       Decimal         @default(1) @db.Decimal(5, 2)
  timeEstimate Int?

  // Optional catalog FK bridges
  catalogChapterId  String?
  catalogLessonId   String?
  catalogQuestionId String? @unique

  options       Json?
  sampleAnswer  String? @db.Text
  gradingRubric String? @db.Text

  tags        String[]
  explanation String?        @db.Text
  source      QuestionSource @default(MANUAL)
  aiPrompt    String?        @db.Text
  imageUrl    String?

  // AI Generation fields
  generationJobId String?
  generationJob   GenerationJob?  @relation(fields: [generationJobId], references: [id])
  sourceId        String?
  sourceMaterial  SourceMaterial? @relation(fields: [sourceId], references: [id])
  aiModel         String?
  generatedAt     DateTime?
  validationScore Decimal?        @db.Decimal(5, 2)

  // Relations
  school                 School                  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  subject                Subject                 @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  generatedExamQuestions GeneratedExamQuestion[]
  analytics              QuestionAnalytics?
  review                 QuestionReview?

  // Catalog bridge relations
  catalogChapter  Chapter?  @relation(fields: [catalogChapterId], references: [id], onDelete: SetNull)
  catalogLesson   Lesson?   @relation(fields: [catalogLessonId], references: [id], onDelete: SetNull)
  catalogQuestion Question? @relation("CatalogQuestionMirror", fields: [catalogQuestionId], references: [id], onDelete: SetNull)

  // Marking system relations
  rubrics        Rubric[]
  studentAnswers StudentAnswer[]
  markingResults MarkingResult[]

  // Quiz game relations
  quizGameQuestions QuizGameQuestion[]

  // Curriculum standards
  standards QuestionStandard[]

  wizardStep String?

  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId, subjectId])
  @@index([schoolId, difficulty, bloomLevel])
  @@index([schoolId, questionType])
  @@index([schoolId, createdBy])
  @@index([schoolId, source])
  @@index([schoolId, generationJobId])
  @@index([validationScore])
  @@index([schoolId, subjectId, questionType])
  @@index([schoolId, subjectId, difficulty])
  @@index([schoolId, tags])
  @@index([createdAt])
  @@index([schoolId, subjectId, bloomLevel])
  @@index([catalogQuestionId])
  @@map("question_bank")
}

model QuestionAnalytics {
  id         String @id @default(cuid())
  schoolId   String
  questionId String @unique

  timesUsed    Int      @default(0)
  avgScore     Decimal? @db.Decimal(5, 2)
  successRate  Float?
  avgTimeSpent Float?

  perceivedDifficulty DifficultyLevel?

  // Psychometric indices
  difficultyIndex     Decimal? @db.Decimal(5, 4)
  discriminationIndex Decimal? @db.Decimal(5, 4)
  pointBiserial       Decimal? @db.Decimal(5, 4)

  distractorAnalysis Json?

  qualityScore      Int?
  qualityFlags      String[]
  recommendedAction String?
  sampleSize        Int      @default(0)
  lastAnalyzedAt    DateTime?

  school   School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  question QuestionBank @relation(fields: [questionId], references: [id], onDelete: Cascade)

  lastUsed  DateTime?
  updatedAt DateTime  @updatedAt

  @@index([schoolId, questionId])
  @@index([schoolId, timesUsed])
  @@index([schoolId, successRate])
  @@index([avgScore])
  @@index([perceivedDifficulty])
  @@index([lastUsed])
  @@index([schoolId, qualityScore])
  @@index([schoolId, recommendedAction])
  @@index([difficultyIndex])
  @@index([discriminationIndex])
  @@map("question_analytics")
}

model QuestionResponse {
  id           String  @id @default(cuid())
  schoolId     String
  questionId   String
  studentId    String
  examId       String

  isCorrect       Boolean
  pointsAwarded   Decimal  @db.Decimal(5, 2)
  maxPoints       Decimal  @db.Decimal(5, 2)
  selectedOptions String[]

  studentTotal Decimal? @db.Decimal(6, 2)
  studentRank  Int?

  responseTime Int?
  createdAt    DateTime @default(now())

  @@unique([examId, questionId, studentId])
  @@index([schoolId])
  @@index([schoolId, questionId])
  @@index([schoolId, examId])
  @@index([schoolId, studentId])
  @@index([schoolId, questionId, isCorrect])
  @@index([questionId, studentRank])
  @@map("question_responses")
}

// ========== EXAM GENERATION ==========

model SchoolExamTemplate {
  id          String  @id @default(cuid())
  schoolId    String
  name        String
  description String? @db.Text
  subjectId   String
  duration    Int
  totalMarks  Decimal @db.Decimal(6, 2)

  distribution      Json
  bloomDistribution Json?

  blockConfig   Json?
  scoringConfig Json?
  printConfig   Json?

  wizardStep   String?
  gradeIds     String[]
  sectionIds   String[]
  classroomIds String[]

  // Catalog bridge FK
  catalogExamTemplateId String?

  school         School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  subject        Subject         @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  generatedExams GeneratedExam[]

  // Catalog bridge relation
  catalogExamTemplate ExamTemplate? @relation("CatalogExamTemplateMirror", fields: [catalogExamTemplateId], references: [id], onDelete: SetNull)

  createdBy String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId, subjectId])
  @@index([schoolId, isActive])
  @@index([schoolId, createdBy])
  @@index([schoolId, subjectId, isActive])
  @@index([catalogExamTemplateId])
  @@index([createdAt])
  @@map("exam_templates")
}

model GeneratedExam {
  id             String  @id @default(cuid())
  schoolId       String
  examId         String
  templateId     String?
  isRandomized   Boolean @default(false)
  isMockEligible Boolean @default(false)
  seed           String?
  totalQuestions Int     @default(0)

  generationNotes String? @db.Text
  wizardStep      String?

  school    School                  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  exam      SchoolExam              @relation(fields: [examId], references: [id], onDelete: Cascade)
  template  SchoolExamTemplate?     @relation(fields: [templateId], references: [id], onDelete: SetNull)
  questions GeneratedExamQuestion[]

  paperConfig ExamPaperConfig?
  answerKey   ExamAnswerKey?

  generatedBy String
  createdAt   DateTime @default(now())

  @@unique([examId])
  @@index([schoolId, examId])
  @@index([schoolId, templateId])
  @@index([schoolId, generatedBy])
  @@index([createdAt])
  @@index([schoolId, isRandomized])
  @@map("generated_exams")
}

model GeneratedExamQuestion {
  id              String  @id @default(cuid())
  schoolId        String
  generatedExamId String
  questionId      String
  order           Int
  points          Decimal @db.Decimal(5, 2)

  customInstructions String? @db.Text

  school        School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  generatedExam GeneratedExam @relation(fields: [generatedExamId], references: [id], onDelete: Cascade)
  question      QuestionBank  @relation(fields: [questionId], references: [id], onDelete: Restrict)

  @@unique([generatedExamId, order])
  @@unique([generatedExamId, questionId])
  @@index([schoolId, generatedExamId])
  @@index([schoolId, questionId])
  @@index([order])
  @@index([points])
  @@map("generated_exam_questions")
}

// ========== AI AUTOMATION SYSTEM ==========

model SourceMaterial {
  id       String @id @default(cuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  title    String
  type     SourceType
  url      String?
  filePath String?
  fileName String?
  fileSize Int?

  author          String?
  publisher       String?
  publicationDate DateTime?
  isbn            String?

  subject  String
  examType String
  language String @default("en")

  status      ProcessingStatus @default(PENDING)
  processedAt DateTime?
  totalPages  Int?
  totalChunks Int              @default(0)

  license     String?
  attribution String  @db.Text
  sourceUrl   String?

  qualityScore Decimal? @db.Decimal(5, 2)
  timesUsed    Int      @default(0)

  chunks    SourceChunk[]
  questions QuestionBank[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId, examType, subject])
  @@index([status])
  @@index([examType])
  @@index([schoolId, type, status])
  @@index([schoolId, subject, status])
  @@index([qualityScore])
  @@index([timesUsed])
  @@map("source_materials")
}

model SourceChunk {
  id       String         @id @default(cuid())
  sourceId String
  source   SourceMaterial @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  content      String  @db.Text
  pageNumber   Int?
  sectionTitle String?
  chapterTitle String?

  embedding String? @db.Text

  chunkIndex Int
  tokenCount Int @default(0)

  questionsGenerated Int       @default(0)
  lastUsed           DateTime?

  createdAt DateTime @default(now())

  @@unique([sourceId, chunkIndex])
  @@index([sourceId])
  @@map("source_chunks")
}

model GenerationJob {
  id       String @id @default(cuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  name         String?
  targetCount  Int
  examType     String
  subjects     String[]
  distribution Json

  aiModel     String  @default("claude-3-5-sonnet-20241022")
  temperature Decimal @default(0.7) @db.Decimal(3, 2)

  status      JobStatus @default(PENDING)
  startedAt   DateTime?
  completedAt DateTime?
  duration    Int?

  questionsGenerated Int @default(0)
  questionsApproved  Int @default(0)
  questionsRejected  Int @default(0)

  avgValidationScore Decimal? @db.Decimal(5, 2)

  errors     Json?
  retryCount Int   @default(0)
  maxRetries Int   @default(3)

  triggeredBy String?

  questions QuestionBank[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId, status])
  @@index([examType])
  @@index([status, createdAt])
  @@index([schoolId, status, createdAt])
  @@index([schoolId, examType, status])
  @@index([triggeredBy])
  @@index([completedAt])
  @@map("generation_jobs")
}

model QuestionReview {
  id         String       @id @default(cuid())
  questionId String       @unique
  question   QuestionBank @relation(fields: [questionId], references: [id], onDelete: Cascade)

  status ReviewStatus @default(PENDING)

  reviewedBy String?
  reviewer   User?     @relation(fields: [reviewedBy], references: [id])
  reviewedAt DateTime?

  approved       Boolean?
  qualityRating  Int?
  accuracyRating Int?

  reviewNotes    String? @db.Text
  suggestedEdits Json?

  flaggedIssues String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([reviewedBy])
  @@index([status, createdAt])
  @@index([status, reviewedAt])
  @@index([qualityRating])
  @@index([accuracyRating])
  @@map("question_reviews")
}
