// Question — catalog-level question bank (NO schoolId)
// ExamQuestion — junction table linking Exam ↔ Question

model Question {
  id               String  @id @default(cuid())
  catalogSubjectId String?
  catalogChapterId String?
  catalogLessonId  String?

  questionText String          @db.Text
  questionType QuestionType
  difficulty   DifficultyLevel
  bloomLevel   BloomLevel
  points       Decimal         @default(1) @db.Decimal(5, 2)

  // Question-specific data (JSON)
  options      Json?
  sampleAnswer String? @db.Text
  explanation  String? @db.Text
  tags         String[] @default([])

  // Contribution pattern
  contributedBy       String?
  contributedSchoolId String?
  approvalStatus      ApprovalStatus    @default(PENDING)
  approvedBy          String?
  approvedAt          DateTime?
  rejectionReason     String?
  visibility          ContentVisibility @default(PUBLIC)

  // Engagement metrics
  usageCount   Int   @default(0)
  averageScore Float @default(0)
  qualityScore Float @default(0)

  status ContentStatus @default(DRAFT)

  // Pricing for PAID visibility
  price    Decimal? @db.Decimal(8, 2)
  currency String?  @default("USD")

  // Relations
  catalogSubject Subject? @relation(fields: [catalogSubjectId], references: [id], onDelete: SetNull)
  catalogChapter Chapter? @relation(fields: [catalogChapterId], references: [id], onDelete: SetNull)
  catalogLesson  Lesson?  @relation(fields: [catalogLessonId], references: [id], onDelete: SetNull)

  // School mirrors (adopted by schools into their QuestionBank)
  schoolMirrors QuestionBank[] @relation("CatalogQuestionMirror")

  // Exam junction
  examQuestions ExamQuestion[]
  quizQuestions QuizQuestion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([catalogSubjectId])
  @@index([catalogChapterId])
  @@index([catalogLessonId])
  @@index([approvalStatus, visibility])
  @@index([questionType, difficulty])
  @@index([contributedBy])
  @@index([contributedSchoolId])
  @@map("catalog_questions")
}

// Junction table: Exam ↔ Question with ordering and points
model ExamQuestion {
  id              String @id @default(cuid())
  catalogExamId   String
  catalogQuestionId String
  order           Int
  points          Decimal @db.Decimal(5, 2)

  // Relations
  exam     Exam     @relation(fields: [catalogExamId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [catalogQuestionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([catalogExamId, order])
  @@unique([catalogExamId, catalogQuestionId])
  @@index([catalogExamId])
  @@index([catalogQuestionId])
  @@map("catalog_exam_questions")
}
