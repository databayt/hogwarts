// Textbook — official course textbooks with TOC mapping (NO schoolId)
// Distinct from Book (library) and Material (supplementary)

model Textbook {
  id           String  @id @default(cuid())
  subjectId    String
  curriculumId String?

  title     String
  slug      String
  lang      String  @default("ar")
  edition   String?
  isbn      String? @unique
  publisher String?
  author    String?

  // File storage
  fileKey   String? // S3 key for PDF
  fileUrl   String?
  fileSize  Int?
  pageCount Int?
  tocMapping Json?  // [{chapterId, page, title}]

  // Cover
  coverKey   String?
  coverColor String?

  grades Int[]       @default([])
  levels SchoolLevel[]
  status ContentStatus @default(PUBLISHED)

  // Relations
  subject    Subject     @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  curriculum Curriculum? @relation(fields: [curriculumId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([subjectId, slug])
  @@index([subjectId])
  @@index([curriculumId])
  @@index([status])
  @@map("catalog_textbooks")
}
