// Conference — video conferencing (LiveKit SFU + external pasted-link providers)
//
// See:
//   src/components/school-dashboard/conference/livekit/*  — server SDK wrappers (rooms, tokens, egress, webhook)
//   src/components/school-dashboard/conference/           — block UI + server actions
//   src/app/api/webhooks/livekit/                         — webhook ingestion
//
// All models are schoolId-scoped. Room name embeds schoolId so the SFU
// namespace cannot leak across tenants. Recordings live in AWS S3
// me-central-1 with PDPL-configurable retention.
//
// Names shortened from LiveClass* → Conference*; DB tables/columns/enum-types
// are preserved verbatim via @@map/@map so this rename is a zero-change migration.

// Meeting provider. `livekit` = built-in SFU room; `external` = pasted meeting
// URL (Google Meet / Zoom / Teams).
enum ConferenceProvider {
  livekit
  external

  @@map("LiveClassProvider")
}

enum ConferenceStatus {
  scheduled
  live
  ended
  cancelled
  failed

  @@map("LiveClassStatus")
}

enum ConferenceRecordingStatus {
  pending // Egress requested, not started
  processing // Egress in flight
  ready // S3 object available
  failed // Egress error
  expired // Past retention, S3 deleted

  @@map("LiveClassRecordingStatus")
}

enum ConferenceParticipantRole {
  HOST // Teacher running the class
  CO_HOST // Co-teacher or observer with publish rights
  PARTICIPANT // Student
  OBSERVER // Parent (subscribe-only)

  @@map("LiveClassParticipantRole")
}

enum ConferenceParticipantStatus {
  invited
  joined
  left
  removed
  no_show

  @@map("LiveClassParticipantStatus")
}

// A scheduled or ad-hoc video conference session.
model Conference {
  id       String @id @default(cuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  // Anchoring — all optional, supports both scheduled (Timetable) and ad-hoc.
  timetableId String?
  timetable   Timetable? @relation(fields: [timetableId], references: [id], onDelete: SetNull)
  sectionId   String?
  section     Section?   @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  subjectId   String?
  subject     Subject?   @relation(fields: [subjectId], references: [id], onDelete: SetNull)

  teacherId String
  teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Restrict)

  // LiveKit metadata
  roomName String  @unique // sch-{schoolId}-lc-{id} — globally unique
  roomSid  String? // LiveKit room SID, set on first connection

  // Provider + external meeting link. `external` sessions store a pasted URL.
  provider        ConferenceProvider @default(livekit)
  meetingUrl      String?
  meetingProvider String?

  // Scheduling
  scheduledStart DateTime
  scheduledEnd   DateTime
  actualStart    DateTime?
  actualEnd      DateTime?

  // State
  status           ConferenceStatus @default(scheduled)
  recordingEnabled Boolean          @default(true)
  maxParticipants  Int              @default(50)

  // Content (single-language storage — see translation rule)
  title       String
  description String? @db.Text
  lang        String  @default("ar")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  participants ConferenceParticipant[]
  recordings   ConferenceRecording[]
  events       ConferenceEvent[]

  @@index([schoolId, status])
  @@index([schoolId, teacherId])
  @@index([schoolId, sectionId])
  @@index([schoolId, scheduledStart])
  @@index([timetableId])
  @@index([deletedAt])
  @@map("live_class_sessions")
}

// One row per user invited to a conference (host, students, observers).
model ConferenceParticipant {
  id         String     @id @default(cuid())
  schoolId   String
  sessionId  String
  conference Conference @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId     String
  user       User       @relation("ConferenceParticipations", fields: [userId], references: [id], onDelete: Cascade)

  role   ConferenceParticipantRole
  status ConferenceParticipantStatus @default(invited)

  tokenIssuedAt   DateTime?
  joinedAt        DateTime?
  leftAt          DateTime?
  durationSeconds Int?

  // Connection-quality telemetry — informs ops, especially Meeting-3 UAE test.
  avgRttMs       Int?
  hadTcpFallback Boolean @default(false) // true if TURN-over-443-TCP was used
  lastIceState   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sessionId, userId])
  @@index([schoolId, userId])
  @@index([schoolId, sessionId])
  @@map("live_class_participants")
}

// Composite room recording produced by LiveKit Egress.
model ConferenceRecording {
  id         String     @id @default(cuid())
  schoolId   String
  school     School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  sessionId  String
  conference Conference @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  egressId String @unique // LiveKit Egress ID
  s3Bucket String
  s3Key    String
  s3Region String @default("me-central-1")

  fileSizeBytes   BigInt?
  durationSeconds Int?
  mimeType        String  @default("video/mp4")

  status      ConferenceRecordingStatus @default(pending)
  startedAt   DateTime?
  completedAt DateTime?
  expiresAt   DateTime?
  deletedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId, status])
  @@index([schoolId, expiresAt])
  @@index([sessionId])
  @@index([deletedAt])
  @@map("live_class_recordings")
}

// Lightweight audit log for room lifecycle + webhook idempotency.
model ConferenceEvent {
  id         String     @id @default(cuid())
  schoolId   String
  sessionId  String
  conference Conference @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  eventType   String // 'room_started','participant_joined','egress_started',...
  actorUserId String?
  payload     Json? // Truncated webhook payload for forensics
  // LiveKit webhook event id — used for idempotent replay protection
  eventId     String? @unique

  occurredAt DateTime @default(now())

  @@index([schoolId, sessionId, occurredAt])
  @@index([schoolId, eventType])
  @@map("live_class_events")
}

// Stable recurring meeting link for a (subject, section, term) — set once,
// reused every week. A Conference scheduled for the day beats this; this is the
// fallback the timetable Join button resolves to when no session-specific link
// exists. Primarily for the `external` provider (Google Meet / Zoom / Teams).
model ConferenceLink {
  id        String  @id @default(cuid())
  schoolId  String
  school    School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  sectionId String
  section   Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  termId    String

  provider        ConferenceProvider @default(external)
  meetingUrl      String
  meetingProvider String?

  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, subjectId, sectionId, termId])
  @@index([schoolId, sectionId])
  @@map("live_class_default_links")
}
