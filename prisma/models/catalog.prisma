// ============================================================================
// CATALOG — The backbone of the platform
// ============================================================================
// This file holds all shared enums and the Subject model (root of the hierarchy).
// Catalog models have NO schoolId — they are platform-wide.
//
// File layout:
//   catalog.prisma   — Enums + Subject (this file)
//   curriculum.prisma — Curriculum
//   chapter.prisma   — Chapter
//   lesson.prisma    — Lesson
//   video.prisma     — Video, Attachment
//   question.prisma  — Question, ExamQuestion
//   exam.prisma      — Exam, ExamTemplate, ExamBlueprint, PaperTemplate
//   quiz.prisma      — Quiz, QuizQuestion
//   assignment.prisma — Assignment
//   material.prisma  — Material
//   book.prisma      — Book
//   textbook.prisma  — Textbook
//   image.prisma     — Image
//   document.prisma  — Document (unified file registry: PDF, PPTX, DOCX, audio, etc.)
//   bridge.prisma    — SubjectSelection, ContentOverride, InstructorPreference, BookSelection
//   enrollment.prisma — Enrollment, LessonProgress, SubjectCertificate
//   proposal.prisma  — Proposal
//
// Repeating field patterns (Prisma has no mixins):
//
//   CONTRIBUTION: contributedBy, contributedSchoolId, approvalStatus,
//                 approvedBy, approvedAt, rejectionReason, visibility
//
//   ENGAGEMENT:   usageCount, averageRating, ratingCount
//
//   HIERARCHY ATTACHMENT: subjectId + chapterId? + lessonId?
//                         (content attaches at any level of the spine)
//
//   MEDIA: concept, imageKey, thumbnailKey, color
// ============================================================================

// === Lifecycle ===

enum ContentStatus {
  DRAFT
  REVIEW
  PUBLISHED
  ARCHIVED
  DEPRECATED
}

// === Academic Structure ===

enum SchoolLevel {
  ELEMENTARY
  MIDDLE
  HIGH
}

// === Community Contribution ===

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ContentVisibility {
  PRIVATE
  SCHOOL
  PUBLIC
  PAID
}

// === Materials ===

enum MaterialType {
  TEXTBOOK
  SYLLABUS
  REFERENCE
  STUDY_GUIDE
  PROJECT
  WORKSHEET
  PRESENTATION
  LESSON_NOTES
  VIDEO_GUIDE
  LAB_MANUAL
  OTHER
}

// === Question Bank ===

enum QuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  SHORT_ANSWER
  ESSAY
  FILL_BLANK
  MATCHING
  ORDERING
  MULTI_SELECT
}

enum DifficultyLevel {
  EASY
  MEDIUM
  HARD
}

enum BloomLevel {
  REMEMBER
  UNDERSTAND
  APPLY
  ANALYZE
  EVALUATE
  CREATE
}

enum QuestionSource {
  MANUAL
  AI
  IMPORTED
}

// === Proposals ===

enum ProposalType {
  SUBJECT
  CHAPTER
  LESSON
  VIDEO
}

enum ProposalStatus {
  DRAFT
  SUBMITTED
  IN_REVIEW
  APPROVED
  REJECTED
  PUBLISHED
}

// ============================================================================
// SUBJECT — Root of the catalog hierarchy
// ============================================================================

model Subject {
  id                String        @id @default(cuid())
  name              String
  slug              String        @unique
  lang              String        @default("ar")
  description       String?       @db.Text
  objectives        String[]      @default([])
  prerequisites     String?       @db.Text
  targetAudience    String?       @db.Text
  department        String // Grouping (e.g. "العلوم")
  levels            SchoolLevel[]
  country           String        @default("SD")
  curriculum        String        @default("national") // "us-k12", "national", "british", "ib"
  curriculumId      String? // FK to Curriculum (Phase 4 backfill)
  catalogCurriculum Curriculum?   @relation(fields: [curriculumId], references: [id], onDelete: SetNull)
  schoolTypes       String[]      @default([]) // [\"international\", \"private\"]. Empty = all.
  concept           String? // "math", "science" — shared image lookup key
  thumbnail         String?       @map("thumbnailKey") // S3 key prefix for thumbnail WebP variants
  banner            String?       @map("bannerUrl") // S3 key prefix for banner WebP variants
  cover             String? // S3 key for textbook cover (one per concept, all grades/curricula)
  pdf               String? // S3 key for textbook PDF (unique per subject)
  color             String?
  tags              String[]      @default([])
  status            ContentStatus @default(PUBLISHED)
  gradeRange        String? // e.g. "1-12", "7-12"
  grades            Int[]         @default([])

  // ClickView integration
  clickviewId  String?
  clickviewUrl String?

  // Pricing
  price    Decimal? @db.Decimal(10, 2)
  currency String?

  // Denormalized counts
  totalChapters Int @default(0)
  totalLessons  Int @default(0)
  totalContent  Int @default(0)

  // Engagement metrics
  usageCount    Int   @default(0)
  averageRating Float @default(0)
  ratingCount   Int   @default(0)

  sortOrder Int @default(0)

  // === Catalog hierarchy ===
  chapters Chapter[]

  // === Catalog content ===
  exams         Exam[]
  questions     Question[]
  materials     Material[]
  assignments   Assignment[]
  books         Book[]
  examTemplates ExamTemplate[]
  textbooks     Textbook[]
  quizzes       Quiz[]
  documents     Document[]

  // === Bridges ===
  subjectSelections     SubjectSelection[]
  instructorPreferences InstructorPreference[]

  // === Engagement ===
  enrollments  Enrollment[]
  certificates SubjectCertificate[]

  // === School-scoped reverse relations ===
  timetableSlots         Timetable[]
  schoolClasses          Class[]
  schoolExams            SchoolExam[]
  schoolExamTemplates    SchoolExamTemplate[]
  schoolQuestionBanks    QuestionBank[]
  schoolResults          Result[]
  liveClassSessions      LiveClassSession[]
  liveClassDefaultLinks  LiveClassDefaultLink[]
  schoolReportGrades     ReportCardGrade[]
  schoolTeacherExpertise TeacherSubjectExpertise[]
  schoolQuickAssessments QuickAssessment[]
  schoolQuizCategories   QuizCategory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([status])
  @@index([country, curriculum])
  @@index([curriculumId])
  @@index([department])
  @@map("catalog_subjects")
}
